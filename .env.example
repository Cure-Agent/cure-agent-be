# ─── 서버 ───────────────────────────────────────────────
PORT=3000

# ─── 데이터베이스 ───────────────────────────────────────
DATABASE_URL=postgres://cure:cure@localhost:5432/cure_agent

# ─── Redis (access 토큰 denylist §4.3, 이후 캐시 공용) ──
REDIS_URL=redis://localhost:6379

# ─── 인증 (architecture.md §4) ──────────────────────────
# 생성: openssl rand -base64 48
AUTH_JWT_SECRET=<openssl rand -base64 48 결과>
AUTH_ACCESS_TTL_SEC=900
AUTH_REFRESH_TTL_DAYS=14
# 쿠키: dev=false/미지정(host-only), prod=true/운영 도메인
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── 필드 암호화 (architecture.md §4.5) ─────────────────
# 32바이트 base64 키. 생성: openssl rand -base64 32
# 키 로테이션 대비 버전 맵 형태이며, ACTIVE_VERSION 키로 신규 암호화한다.
CRYPTO_ENC_KEYS={"v1":"<openssl rand -base64 32 결과>"}
CRYPTO_ENC_ACTIVE_VERSION=v1
# HMAC blind index 키 (검색용, 32바이트 이상 base64)
CRYPTO_HMAC_INDEX_KEY=<openssl rand -base64 32 결과>

# ─── 실시간 장애 알림 (architecture.md §14, 선택) ───────
# Discord/Slack webhook URL. 비우면 알림 비활성.
ALERT_WEBHOOK_URL=

# ─── 실 LLM 프로바이더 (docs/specs/13, 전부 선택) ───────
# API 키를 넣은 프로바이더만 등록되고, 우선순위는 openai → anthropic이다.
# 키가 하나도 없으면 결정적 fake 단독으로 동작한다(로컬·CI 기본값).
# 반대로 실 프로바이더가 하나라도 등록되면 fake는 폴백에서 제외된다 —
# 전 프로바이더 실패는 fake 답변이 아니라 503(LLM_UNAVAILABLE)이어야 하기 때문이다.
OPENAI_API_KEY=
# 모델·엔드포인트는 프로바이더 문서 기준으로 갱신한다 (미지정 시 아래 기본값)
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# 답변 최대 출력 토큰 (공통)
LLM_MAX_OUTPUT_TOKENS=1024
